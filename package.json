{
  "name": "envguard-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "EnvGuard npm workspace and release tooling.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspace @bhargavmahanta/envguard",
    "lint": "npm run lint --workspace @bhargavmahanta/envguard",
    "typecheck": "npm run typecheck --workspace @bhargavmahanta/envguard",
    "test:package": "npm run test:package --workspace @bhargavmahanta/envguard",
    "security:env": "npm run security:env --workspace @bhargavmahanta/envguard",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "release:dry": "npm run typecheck && npm run lint && npm test && npm audit && npm run test:package && npm pack --dry-run --workspaces"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}

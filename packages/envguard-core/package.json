{
  "name": "@bhargavmahanta/envguard-core",
  "version": "1.0.0",
  "description": "Presentation-free scanning, configuration, rules, errors, and types for EnvGuard.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Bhargav Mahanta",
  "license": "MIT",
  "homepage": "https://github.com/bhargavmahanta/envGuard#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhargavmahanta/envGuard.git",
    "directory": "packages/envguard-core"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "js-yaml": "^5.2.1",
    "picomatch": "^4.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.5.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}

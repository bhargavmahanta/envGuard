{
  "name": "@bhargavmahanta/envguard",
  "version": "2.0.1",
  "description": "Security linter for environment variables, Docker, CI, Kubernetes, and runtime configuration.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Bhargav Mahanta",
  "license": "MIT",
  "homepage": "https://github.com/bhargavmahanta/envGuard#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/bhargavmahanta"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhargavmahanta/envGuard.git"
  },
  "bugs": {
    "url": "https://github.com/bhargavmahanta/envGuard/issues"
  },
  "bin": {
    "envguard": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./reporters": {
      "types": "./dist/reporters/index.d.ts",
      "import": "./dist/reporters/index.js",
      "require": "./dist/reporters/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli-entry.ts",
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:consumers": "node test/package-consumers.mjs",
    "test:package": "npm run build && npm run test:consumers",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "security:env": "tsx src/cli.ts scan . --ci --fail-on high",
    "release:dry": "npm run typecheck && npm run lint && npm test && npm audit && npm run test:package && npm pack --dry-run && npm publish --dry-run --access public"
  },
  "keywords": [
    "security",
    "devsecops",
    "appsec",
    "secrets-scanner",
    "dotenv",
    "cli",
    "typescript",
    "github-actions",
    "docker-security",
    "configuration-security",
    "environment-variables",
    "env-security",
    "configuration-linting",
    "kubernetes-security",
    "helm-security",
    "ci-security",
    "mcp-server",
    "security-linter"
  ],
  "dependencies": {
    "@bhargavmahanta/envguard-core": "^1.0.0",
    "@bhargavmahanta/envguard-reporters": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}

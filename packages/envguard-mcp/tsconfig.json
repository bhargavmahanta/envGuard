{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@bhargavmahanta/envguard-core": ["../envguard-core/src/index.ts"],
      "@bhargavmahanta/envguard-reporters": ["../envguard-reporters/src/index.ts"]
    },
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "src",
    "test/**/*.test.ts",
    "../envguard-core/src/picomatch.d.ts",
    "tsup.config.ts",
    "vitest.config.ts"
  ]
}

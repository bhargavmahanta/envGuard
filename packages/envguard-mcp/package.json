{
  "name": "@bhargavmahanta/envguard-mcp",
  "version": "1.0.0",
  "description": "Restricted, masked stdio MCP server for EnvGuard.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Bhargav Mahanta",
  "license": "MIT",
  "homepage": "https://github.com/bhargavmahanta/envGuard#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhargavmahanta/envGuard.git",
    "directory": "packages/envguard-mcp"
  },
  "bin": {
    "envguard-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run"
  },
  "dependencies": {
    "@bhargavmahanta/envguard-core": "^1.0.0",
    "@bhargavmahanta/envguard-reporters": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsup": "^8.1.0",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
